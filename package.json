{
  "name": "moses-agent",
  "version": "1.0.2",
  "description": "Downloadable Moses orchestrator agent package for OpenCode.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jangisaac-dev/moses-agent.git"
  },
  "homepage": "https://github.com/jangisaac-dev/moses-agent",
  "bugs": {
    "url": "https://github.com/jangisaac-dev/moses-agent/issues"
  },
  "bin": {
    "moses-agent": "./bin/moses-install.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "README.ko.md",
    "LICENSE",
    "install.sh",
    "uninstall.sh",
    "docs"
  ],
  "scripts": {
